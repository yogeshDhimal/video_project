# Server
PORT=5000
# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/streamvault

# Auth: use a long random string in production (32+ chars)
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Frontend URL (CORS + email links). Must match where you open the React app.
CLIENT_URL=http://localhost:5173

# Optional: email for verification & password reset (leave empty = console log only)
# SMTP host, e.g. smtp.gmail.com, smtp.sendgrid.net, or your mail provider
EMAIL_HOST=smtp.gmail.com
# Usually 587 (TLS) or 465 (SSL)
EMAIL_PORT=587
# SMTP username (often your full email address)
EMAIL_USER=yogeshdhimal0@gmail.com
# SMTP password or app-specific password
EMAIL_PASS=oqqa wstd gzuo cvrm
# From address shown to users
EMAIL_FROM=noreply@streamvault.local
